{
  "name": "@deessejs/cli",
  "version": "0.6.3",
  "description": "DeesseJS CLI for managing DeesseJS projects",
  "type": "module",
  "bin": {
    "deesse": "./bin/deesse.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "deessejs",
    "deesse"
  ],
  "author": "DeesseJS",
  "license": "MIT",
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.0.0",
    "@clack/prompts": "^0.8.2",
    "better-auth": "^1.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
