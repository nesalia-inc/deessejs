{
  "name": "@deessejs/next",
  "version": "0.1.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./routes": {
      "import": "./dist/routes/index.js",
      "types": "./dist/routes/index.d.ts"
    },
    "./root-layout": {
      "import": "./dist/components/root-layout.js",
      "types": "./dist/components/root-layout.d.ts"
    },
    "./to-sidebar-items": {
      "import": "./dist/lib/to-sidebar-items.js",
      "types": "./dist/lib/to-sidebar-items.d.ts"
    },
    "./app-sidebar": {
      "import": "./dist/components/app-sidebar.js",
      "types": "./dist/components/app-sidebar.d.ts"
    },
    "./admin-shell": {
      "import": "./dist/components/admin-shell.js",
      "types": "./dist/components/admin-shell.d.ts"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@deessejs/admin": "^0.1.0",
    "@deessejs/ui": "0.3.2",
    "better-auth": "^1.0.0",
    "deesse": "^0.2.12",
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "@deessejs/ui": "0.3.2",
    "deesse": "^0.2.11",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
